# Financial Statement Extractor - Environment Configuration
# Copy this file to .env and customize as needed

# Default model for all tasks
DEFAULT_MODEL=qwen3.5:397b-cloud

# Model for page detection and data extraction (overrides DEFAULT_MODEL)
# EXTRACTION_MODEL=qwen3.5:9b

# Model for LLM-as-Judge evaluation (overrides DEFAULT_MODEL)
# EVALUATION_MODEL=qwen3.5:9b

# Enable VLM verification (true/false)
# USE_VLM_VERIFICATION=false

# Enable observability and metrics logging (true/false)
# ENABLE_OBSERVABILITY=true
